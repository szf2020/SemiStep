<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="UI.Controls.RecipeMenuBar">

    <Menu>
        <MenuItem Header="_File">
            <MenuItem Header="_New Recipe"
                      Command="{Binding NewRecipeCommand}" />
            <MenuItem Header="_Open Recipe..."
                      Command="{Binding LoadRecipeCommand}"
                      InputGesture="Ctrl+O" />
            <MenuItem Header="_Save Recipe"
                      Command="{Binding SaveRecipeCommand}"
                      InputGesture="Ctrl+S" />
            <MenuItem Header="Save Recipe _As..."
                      Command="{Binding SaveAsRecipeCommand}"
                      InputGesture="Ctrl+Shift+S" />
            <Separator />
            <MenuItem Header="E_xit"
                      Command="{Binding ExitCommand}"
                      InputGesture="Alt+F4" />
        </MenuItem>

        <MenuItem Header="_Edit">
            <MenuItem Header="_Add Step"
                      Command="{Binding AddStepCommand}"
                      InputGesture="Ctrl+N" />
            <MenuItem Header="_Delete Step"
                      Command="{Binding DeleteStepCommand}"
                      InputGesture="Delete" />
            <Separator />
            <MenuItem Header="Cop_y Steps"
                      Command="{Binding CopyStepCommand}"
                      InputGesture="Ctrl+C" />
            <MenuItem Header="Cu_t Steps"
                      Command="{Binding CutStepCommand}"
                      InputGesture="Ctrl+X" />
            <MenuItem Header="_Paste Steps"
                      Command="{Binding PasteStepCommand}"
                      InputGesture="Ctrl+V" />
            <Separator />
            <MenuItem Header="_Undo"
                      Command="{Binding UndoCommand}"
                      InputGesture="Ctrl+Z" />
            <MenuItem Header="_Redo"
                      Command="{Binding RedoCommand}"
                      InputGesture="Ctrl+Shift+Z" />
        </MenuItem>
        <MenuItem Header="_View">
            <MenuItem Header="_Notification Log"
                      Command="{Binding LogPanel.ToggleCommand}" />
        </MenuItem>

        <MenuItem Header="_Help">
            <MenuItem Header="_About"
                      IsEnabled="False" />
        </MenuItem>
    </Menu>

</UserControl>
